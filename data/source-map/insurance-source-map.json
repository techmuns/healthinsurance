{
  "$schema_version": "1.0.0",
  "_meta": {
    "purpose": "Single source of truth for every metric the dashboard renders. Each entry maps a metric_id to its official source. No metric may appear in the UI unless it exists in this file.",
    "rules": [
      "Only official sources: IRDAI portal, company IR / financial disclosure pages, exchanges (NSE/BSE) for listed insurers, GI Council for industry stats.",
      "No broker reports, news sites, Screener, Tijori, Moneycontrol, Trendlyne or any unofficial source for the core dataset.",
      "Every metric must declare frequency, source_priority, parser_status and confidence_level.",
      "Raw source files must be stored under data/raw/ before parsing."
    ],
    "last_updated": "2026-05-28",
    "maintainer": "data-pipeline"
  },
