{
  "_meta": {
    "registry_id": "company-source-registry",
    "description": "Per-company OFFICIAL source registry for the Excel pipeline. FK-joined to src/data/snapshots/company-master.json on company_id (the identity source of truth). Drives the (Chunk 2) company-filings adapter + the bridge's source-priority resolver. Chunk 1 = registry + inventory only; no parser/bridge changes yet.",
    "schema_version": "1.0.0",
    "dataset": "official",
    "source_policy": "official-first, login-free. URLs are public landing / disclosure pages only. From this cloud box every official site returns 403, so newly-added URLs are tagged verification_status='best_known_unverified' and must be confirmed on the first live (CI / manual-drop) fetch. Nothing here is fabricated data; these are source pointers.",
    "last_updated": "2026-06-05",
    "exclusions": "Entities flagged in company-master.json with source_scope='irdai_industry_only' (e.g. reliance-health, a defunct SAHI line) are intentionally NOT in this registry: they carry no company-filing source expectations and must not generate filing/inventory/missing-data rows. Their historical values come only from IRDAI industry data (schema-map source_key='industry_premium').",
    "source_priority_profiles": {
      "_doc": "Ranked list of which URL field to trust per metric group. The bridge derives source_priority_rank = index. screener_backup / trendlyne_backup / investing_price_only are synthetic backup tokens, always lowest. Backups never override an official value unless it is missing or stale.",
      "listed": {
        "annual": ["annual_report_url", "public_disclosure_url", "irda_public_disclosure_url", "investor_relations_url", "nse_filing_url", "bse_filing_url", "screener_backup", "investing_price_only"],
        "quarterly": ["quarterly_ppt_url", "quarterly_results_url", "public_disclosure_url", "irda_public_disclosure_url", "nse_filing_url", "bse_filing_url", "screener_backup"],
        "monthly": ["irda_public_disclosure_url", "investor_relations_url"]
      },
      "unlisted": {
        "annual": ["annual_report_url", "public_disclosure_url", "irda_public_disclosure_url", "investor_relations_url", "screener_backup"],
        "quarterly": ["quarterly_ppt_url", "quarterly_results_url", "public_disclosure_url", "irda_public_disclosure_url", "screener_backup"],
        "monthly": ["irda_public_disclosure_url", "investor_relations_url"]
      },
      "psu": {
        "annual": ["annual_report_url", "public_disclosure_url", "irda_public_disclosure_url", "investor_relations_url"],
        "quarterly": ["public_disclosure_url", "irda_public_disclosure_url", "quarterly_results_url"],
        "monthly": ["irda_public_disclosure_url"]
      },
      "listed_parent_supplementary": {
        "_doc": "Religare Enterprises (Care's listed parent). SUPPLEMENTARY ONLY for Care. See care_religare_policy below.",
        "annual": ["annual_report_url", "investor_relations_url", "nse_filing_url", "bse_filing_url"],
        "quarterly": ["quarterly_ppt_url", "quarterly_results_url", "investor_relations_url", "nse_filing_url"]
      }
    },
    "care_religare_policy": {
      "primary_for_care": "care-health own public disclosures (irda_public_disclosure_url + public_disclosure_url). These are the source of truth for Care's granular metrics.",
      "religare_role": "SUPPLEMENTARY ONLY. Religare Enterprises is Care's listed parent; its investor PPT / results add context and a few Care KPIs.",
      "hard_rule": "NEVER map a Religare consolidated / group number onto Care Health unless the figure is explicitly labelled 'Care Health' or 'Care Health Insurance' in the Religare document. A Religare-sourced Care value must carry source_company='religare-enterprises', metric_label_verbatim, and require_explicit_care_label=true; otherwise it is rejected, not guessed."
    }
  },
