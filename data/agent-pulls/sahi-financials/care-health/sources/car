  function _b64url(str) {
    return btoa(unescape(encodeURIComponent(str)))
      .replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/, "");
  }

  function _b64urlBytes(bytes) {
    var bin = "";
    for (var i = 0; i < bytes.length; i++) { bin += String.fromCharCode(bytes[i]); }
    return btoa(bin).replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/, "");
  }

  function _buildAsapJwt(user) {
    if (!window.crypto || !window.crypto.subtle || !window.TextEncoder) { return Promise.reject(new Error("WebCrypto not available")); }
    var now = Date.now();
    var signingInput = _b64url(JSON.stringify({ alg: "HS256", typ: "JWT" })) + "." +
      _b64url(JSON.stringify({
        email_verified: true,
        not_before:     now,
        not_after:      now + _ASAP_JWT_TTL_MS,
        email:          user.user_email  || "",
        first_name:     user.user_fname  || "",
        last_name:      user.user_lname  || ""
