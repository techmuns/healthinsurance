{
  "name": "insurance-investor-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "python3 scripts/excel/build_audit_index.py || echo 'audit index: python unavailable — using committed index'",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "ingest": "tsx scripts/ingest/ingest-all.ts",
    "ingest:monthly": "CADENCE=monthly tsx scripts/ingest/ingest-all.ts",
    "ingest:quarterly": "CADENCE=quarterly tsx scripts/ingest/ingest-all.ts",
    "ingest:annual": "CADENCE=annual tsx scripts/ingest/ingest-all.ts",
    "ingest:filings": "tsx scripts/ingest/fetch-company-filings.ts",
    "ingest:gic-segment-annual": "tsx scripts/ingest/run-gic-segment-annual.ts",
    "ingest:audit": "tsx scripts/ingest/audit-fill.ts fill",
    "audit:index": "python3 scripts/excel/build_audit_index.py",
    "audit:build": "python3 scripts/excel/build_audit_index.py",
    "audit:missing": "tsx scripts/ingest/audit-fill.ts missing",
    "audit:conflicts": "tsx scripts/ingest/audit-fill.ts conflicts",
    "audit:niva-bupa:inspect": "tsx scripts/ingest/niva-backfill.ts",
    "audit:niva-bupa:backfill": "tsx scripts/ingest/niva-backfill.ts && tsx scripts/ingest/audit-fill.ts fill --from data/agent-pulls/niva-backfill/cleaned.json"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.19.19",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cheerio": "^1.2.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "pdf-parse": "^1.1.4",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^5.4.11",
    "wrangler": "^4.40.0"
  }
}
